#!/usr/bin/env node
'use strict';

/**
 * Reverse proxy wrapper for Claude Code that intercepts and logs token consumption.
 * Zero npm dependencies — Node.js built-ins only.
 *
 * Usage:
 *   ddbya [claude args...]
 *   ddbya -t <tag> [claude args...]
 */

const fs = require('fs');
const path = require('path');
const os = require('os');
const crypto = require('crypto');
const { spawn } = require('child_process');
const {
  DDBYA_DIR,
  USAGE_FILENAME_PREFIX,
  DEFAULT_UPSTREAM,
  resolveIdentity,
  TokenLogger,
  buildProxy,
} = require(path.join(__dirname, 'proxy-core.js'));

const USAGE_GLOB_RE = /^usage-.+\.ddbya$/;

const HELP = `\
Usage: ddbya [OPTIONS] [CLAUDE_ARGS...]

Reverse proxy wrapper for Claude Code that intercepts and logs token consumption.
All arguments not listed below are forwarded to claude unchanged.

Options:
  -t, --tag <tag>   Tag this session's consumption. Can be given multiple times.
                    Also reads DDBYA_TAGS env var (comma-separated); -t appends.
  --list-tags       Print all tags used in this and sibling projects, then exit.
                    Used by shell completions for tab-completing -t values.
  -h, --help        Show this message and exit.

Token usage is written to .ddbya.d/usage-<identity>-<session>.ddbya in the
current directory. A summary is printed to stderr when the session ends.

Examples:
  ddbya
  ddbya -t "client-acme" -t "code review"
  ddbya --model claude-sonnet-4-6`;

// ── Argument parsing ──────────────────────────────────────────────────────────

function parseArgs(argv) {
  const tags = [];
  let listTags = false;
  let showHelp = false;
  const claudeArgs = [];
  let i = 0;
  while (i < argv.length) {
    const arg = argv[i];
    if (arg === '-h' || arg === '--help') {
      showHelp = true; i++;
    } else if (arg === '-t' || arg === '--tag') {
      if (i + 1 >= argv.length) {
        process.stderr.write('error: -t/--tag requires a value\n');
        process.exit(1);
      }
      tags.push(argv[++i]); i++;
    } else if (arg === '--list-tags') {
      listTags = true; i++;
    } else {
      claudeArgs.push(arg); i++;
    }
  }
  const envTags = (process.env.DDBYA_TAGS || '').split(',').map(t => t.trim()).filter(Boolean);
  return { tags: [...envTags, ...tags], listTags, showHelp, claudeArgs };
}

// ── Tag collection ────────────────────────────────────────────────────────────

function claudeDesktopLogRoot() {
  if (process.platform === 'darwin') return path.join(os.homedir(), 'Library', 'Application Support', 'ddbya');
  if (process.platform === 'win32') {
    const appdata = process.env.APPDATA;
    return appdata ? path.join(appdata, 'ddbya') : null;
  }
  const xdg = process.env.XDG_DATA_HOME || path.join(os.homedir(), '.local', 'share');
  return path.join(xdg, 'ddbya');
}

function collectTagsFromDir(rootDir) {
  const tags = new Set();

  function readJsonlFile(filePath) {
    try {
      const lines = fs.readFileSync(filePath, 'utf8').split('\n');
      for (const line of lines) {
        if (!line.trim()) continue;
        try {
          const entry = JSON.parse(line);
          if (Array.isArray(entry.tags)) {
            entry.tags.forEach(t => typeof t === 'string' && tags.add(t));
          }
        } catch {}
      }
    } catch {}
  }

  function walk(dir) {
    let entries;
    try { entries = fs.readdirSync(dir, { withFileTypes: true }); } catch { return; }
    for (const entry of entries) {
      const full = path.join(dir, entry.name);
      if (entry.isDirectory()) {
        if (entry.name === DDBYA_DIR) {
          let files;
          try { files = fs.readdirSync(full); } catch { continue; }
          for (const f of files) {
            if (USAGE_GLOB_RE.test(f)) readJsonlFile(path.join(full, f));
          }
        } else {
          walk(full);
        }
      } else if (entry.name === '.token-usage.ddbya') {
        readJsonlFile(full);
      }
    }
  }
  walk(rootDir);
  return tags;
}

function findTagRoot(startDir) {
  let current = path.resolve(startDir);
  while (true) {
    const parent = path.dirname(current);
    if (parent === current) return current;
    if (!fs.existsSync(path.join(parent, DDBYA_DIR))) return current;
    current = parent;
  }
}

function collectTags(projectDir) {
  const root = findTagRoot(projectDir);
  const tags = collectTagsFromDir(root);
  const cdRoot = claudeDesktopLogRoot();
  if (cdRoot && fs.existsSync(cdRoot)) {
    collectTagsFromDir(cdRoot).forEach(t => tags.add(t));
  }
  return [...tags].sort((a, b) => a.toLowerCase().localeCompare(b.toLowerCase()));
}

// ── Legacy migration ──────────────────────────────────────────────────────────

function migrateLegacyLayout(projectDir, identity, sessionId) {
  const ddbyaDir = path.join(projectDir, DDBYA_DIR);
  fs.mkdirSync(ddbyaDir, { recursive: true });
  const legacy = path.join(projectDir, '.token-usage.ddbya');
  if (fs.existsSync(legacy)) {
    const targetName = `${USAGE_FILENAME_PREFIX}${identity}-${sessionId}.ddbya`;
    const target = path.join(ddbyaDir, targetName);
    fs.renameSync(legacy, target);
    process.stderr.write(`ddbya: migrated .token-usage.ddbya → .ddbya.d/${targetName}\n`);
  }
}

// ── Session summary ───────────────────────────────────────────────────────────

function formatSummary(input, output, cacheRead, cacheCreate, count) {
  const total = input + output + cacheRead + cacheCreate;
  const lines = [
    '\nSession token usage:',
    `  Requests:     ${count}`,
    `  Input:        ${input.toLocaleString('en-US')} tokens`,
    `  Output:       ${output.toLocaleString('en-US')} tokens`,
  ];
  if (cacheRead) lines.push(`  Cache read:   ${cacheRead.toLocaleString('en-US')} tokens`);
  if (cacheCreate) lines.push(`  Cache write:  ${cacheCreate.toLocaleString('en-US')} tokens`);
  lines.push(`  Total:        ${total.toLocaleString('en-US')} tokens`);
  return lines.join('\n');
}

// ── Main ──────────────────────────────────────────────────────────────────────

async function main() {
  const { tags, listTags, showHelp, claudeArgs } = parseArgs(process.argv.slice(2));

  if (showHelp) {
    process.stdout.write(HELP + '\n');
    process.exit(0);
  }

  if (listTags) {
    for (const tag of collectTags(process.cwd())) {
      process.stdout.write(tag + '\n');
    }
    process.exit(0);
  }

  const upstream = process.env.ANTHROPIC_BASE_URL || DEFAULT_UPSTREAM;
  const identity = resolveIdentity();
  const sessionId = crypto.randomUUID().replace(/-/g, '').slice(0, 8);
  const projectDir = process.cwd();

  migrateLegacyLayout(projectDir, identity, sessionId);

  const logPath = path.join(projectDir, DDBYA_DIR, `${USAGE_FILENAME_PREFIX}${identity}-${sessionId}.ddbya`);
  const logger = new TokenLogger(logPath);
  const server = buildProxy(upstream, logger, () => tags, {});

  await new Promise((resolve, reject) => {
    server.once('error', reject);
    server.listen(0, '127.0.0.1', resolve);
  });

  const port = server.address().port;
  const env = { ...process.env, ANTHROPIC_BASE_URL: `http://127.0.0.1:${port}` };

  // Prevent Node.js from exiting on SIGINT — the terminal sends it to the whole
  // process group, so claude receives it directly and handles its own shutdown.
  // We wait for claude to close before cleaning up.
  process.on('SIGINT', () => {});
  process.on('SIGTERM', () => { if (child) child.kill('SIGTERM'); });

  let child;
  try {
    child = spawn('claude', claudeArgs, { env, stdio: 'inherit' });
  } catch (err) {
    server.close();
    logger.close();
    if (err.code === 'ENOENT') {
      process.stderr.write(
        "error: 'claude' executable not found on PATH. " +
        'Install Claude Code (https://claude.ai/claude-code) and try again.\n',
      );
      process.exit(127);
    }
    throw err;
  }

  child.on('error', err => {
    server.close();
    logger.close();
    if (err.code === 'ENOENT') {
      process.stderr.write(
        "error: 'claude' executable not found on PATH. " +
        'Install Claude Code (https://claude.ai/claude-code) and try again.\n',
      );
      process.exit(127);
    }
    process.stderr.write(`error: ${err.message}\n`);
    process.exit(1);
  });

  child.on('close', code => {
    server.close();
    logger.close();
    const { input, output, cacheRead, cacheCreate, count } = logger.summary();
    if (count > 0) {
      process.stderr.write(formatSummary(input, output, cacheRead, cacheCreate, count) + '\n');
    }
    process.exit(code != null ? code : 0);
  });
}

main().catch(err => {
  process.stderr.write(`error: ${err.message}\n`);
  process.exit(1);
});
