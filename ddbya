#!/usr/bin/env python3
"""
Reverse proxy wrapper for Claude Code that intercepts and logs token consumption.
Zero dependencies — Python 3 standard library only.

Usage:
    ddbya [claude args...]
    ddbya -o <ollama-model> [claude args...]
    ddbya -l <limit> --last <days> [claude args...]
    ddbya -t <tag> [claude args...]

Options:
    -o, --ollama-model <model>  Route through Ollama with the given model.
                                Sets the upstream to OLLAMA_HOST (default
                                127.0.0.1:11434) and configures auth.
    -l, --limit <USD>          Budget limit in US dollars. Requires --last.
                                Not supported with -o/--ollama-model.
    --last <days>              Number of days to look back for budget tracking.
                                Required when -l/--limit is set.
    -t, --tag <tag>            Tag to label this session's consumption. Can be
                                given multiple times. Tags are written into
                                each token-usage.jsonl entry.

The proxy writes token usage to ./token-usage.jsonl in the current directory
and prints a summary to stderr when the session ends.
"""

import sys
import os
import gzip
import zlib
import json
import threading
import subprocess
import http.server
import http.client
import urllib.parse
import signal
import time
from datetime import datetime, timedelta, timezone
from pathlib import Path

TOKEN_LOG_FILE = "token-usage.jsonl"
DEFAULT_UPSTREAM = "https://api.anthropic.com"
OLLAMA_DEFAULT_HOST = "127.0.0.1:11434"

# Pricing per million tokens (USD), scraped from platform.claude.com/docs/en/about-claude/pricing.
# Key: model ID prefix → {input, output, cache_write (5m), cache_read}
# Matched by longest prefix first against the model string returned by the API.
MODEL_PRICING = {
    "claude-opus-4-7":   {"input": 5,    "output": 25,  "cache_write": 6.25, "cache_read": 0.50},
    "claude-opus-4-6":   {"input": 5,    "output": 25,  "cache_write": 6.25, "cache_read": 0.50},
    "claude-opus-4-5":   {"input": 5,    "output": 25,  "cache_write": 6.25, "cache_read": 0.50},
    "claude-opus-4-1":   {"input": 15,   "output": 75,  "cache_write": 18.75,"cache_read": 1.50},
    "claude-opus-4":     {"input": 15,   "output": 75,  "cache_write": 18.75,"cache_read": 1.50},
    "claude-sonnet-4-6": {"input": 3,    "output": 15,  "cache_write": 3.75, "cache_read": 0.30},
    "claude-sonnet-4-5": {"input": 3,    "output": 15,  "cache_write": 3.75, "cache_read": 0.30},
    "claude-sonnet-4":   {"input": 3,    "output": 15,  "cache_write": 3.75, "cache_read": 0.30},
    "claude-haiku-4-5":  {"input": 1,    "output": 5,   "cache_write": 1.25, "cache_read": 0.10},
    "claude-haiku-3-5":  {"input": 0.80, "output": 4,   "cache_write": 1.0,  "cache_read": 0.08},
}
_DEFAULT_PRICING = MODEL_PRICING["claude-sonnet-4-6"]

# Sorted keys for longest-prefix-first matching
_MODEL_PRICING_PREFIXES = sorted(MODEL_PRICING.keys(), key=len, reverse=True)

# Budget warning thresholds (percent of limit). Below 100% only — at/above 100%
# the exceeded message (pre-flight or watchdog) carries the same info.
_BUDGET_WARN_THRESHOLDS = (80, 85, 90, 95, 96, 97, 98, 99)


class BudgetChecker:
    """Periodically scans token-usage.jsonl across sibling projects to enforce a budget."""

    def __init__(self, limit_usd, lookback_days, project_dir,
                 check_interval=60, on_exceeded=None, is_idle=None):
        self._limit_usd = limit_usd
        self._lookback = timedelta(days=lookback_days)
        self._project_dir = Path(project_dir).resolve()
        self._parent_dir = self._project_dir.parent
        self._check_interval = check_interval
        self._on_exceeded = on_exceeded
        # Optional callable returning True when it's safe to print a warning
        # (no in-flight proxied requests, so claude's TUI is not actively
        # repainting on top of our stderr output). If None, warnings print
        # immediately on every threshold crossing.
        self._is_idle = is_idle
        self._pending_warning = None
        self._lock = threading.Lock()
        self._current_cost = 0.0
        self._limit_exceeded = False
        self._last_notified_pct = -1
        self._unknown_models = set()
        self._warned_models = set()
        self._running = False
        self._thread = None
        self._first_check_done = threading.Event()
        # Per-file cache: avoids re-reading entire JSONL logs every tick.
        # path -> {"mtime": float, "offset": int, "entries": [(datetime, float)]}.
        # Only newly-appended bytes are read; old entries are pruned once they
        # fall outside the budget window.
        self._file_cache = {}

    def start(self):
        self._running = True
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()

    def stop(self):
        self._running = False

    def wait_first_check(self):
        self._first_check_done.wait()

    @property
    def limit_exceeded(self):
        with self._lock:
            return self._limit_exceeded

    @property
    def current_cost(self):
        with self._lock:
            return self._current_cost

    @property
    def unknown_models(self):
        with self._lock:
            return sorted(self._unknown_models)

    def _run(self):
        self._check()
        self._first_check_done.set()
        while self._running:
            time.sleep(self._check_interval)
            if self._running:
                self._check()

    def _check(self):
        now = datetime.now(timezone.utc)
        since = now - self._lookback

        log_files = []

        # Current project
        log_file = self._project_dir / TOKEN_LOG_FILE
        if log_file.exists():
            log_files.append(log_file)

        # Sibling projects in the parent directory
        if self._parent_dir.exists():
            try:
                for entry in self._parent_dir.iterdir():
                    if not entry.is_dir() or entry.resolve() == self._project_dir:
                        continue
                    sibling_log = entry / TOKEN_LOG_FILE
                    if sibling_log.exists():
                        log_files.append(sibling_log)
            except PermissionError:
                pass

        total_cost = 0.0
        for f in log_files:
            total_cost += self._cost_from_file(f, since)

        # Drop cache entries for files that have vanished since the last tick.
        live = set(log_files)
        for path in list(self._file_cache):
            if path not in live:
                del self._file_cache[path]

        with self._lock:
            self._current_cost = total_cost

        if self._limit_usd <= 0:
            return

        pct = int(total_cost / self._limit_usd * 100)

        # Warn on crossing a threshold rather than landing on it: spend can
        # jump several percentage points between ticks. On the first tick of a
        # session that starts already past one or more thresholds, fire a
        # single warning at the highest crossed threshold so the user is told
        # once rather than spammed for every threshold below their current pct.
        if pct < 100:
            crossed = [t for t in _BUDGET_WARN_THRESHOLDS
                       if t <= pct and t > self._last_notified_pct]
            if crossed:
                # Stash the latest message; a fresh crossing on a later tick
                # supersedes a still-pending one (we only ever show the most
                # recent budget state).
                self._pending_warning = f"\nBudget: ${total_cost:.2f} / ${self._limit_usd:.2f} ({pct}%)."
                self._last_notified_pct = crossed[-1]

        # Flush a pending warning only when the proxy is idle, so claude's
        # TUI doesn't immediately repaint over it mid-stream.
        if self._pending_warning is not None:
            if self._is_idle is None or self._is_idle():
                print(self._pending_warning, file=sys.stderr)
                self._pending_warning = None

        if pct >= 100:
            fire_callback = False
            with self._lock:
                if not self._limit_exceeded:
                    fire_callback = True
                self._limit_exceeded = True
            if fire_callback and self._on_exceeded is not None:
                try:
                    self._on_exceeded()
                except Exception:
                    pass

    def _cost_from_file(self, filepath, since):
        try:
            st = filepath.stat()
        except OSError:
            return 0.0

        cache = self._file_cache.get(filepath)
        if cache is None:
            cache = {"mtime": 0.0, "offset": 0, "entries": []}
            self._file_cache[filepath] = cache

        # File rotated or truncated — discard cached state and start over.
        if st.st_size < cache["offset"]:
            cache["offset"] = 0
            cache["entries"] = []
            cache["mtime"] = 0.0

        if st.st_size > cache["offset"] or st.st_mtime != cache["mtime"]:
            try:
                with open(filepath, "rb") as f:
                    f.seek(cache["offset"])
                    while True:
                        line = f.readline()
                        if not line:
                            break
                        if not line.endswith(b"\n"):
                            # Partial write at EOF — leave it for the next tick.
                            f.seek(-len(line), 1)
                            break
                        try:
                            entry = json.loads(line)
                        except json.JSONDecodeError:
                            continue
                        ts_raw = entry.get("timestamp", "")
                        if not isinstance(ts_raw, str):
                            continue
                        try:
                            entry_time = datetime.fromisoformat(ts_raw.replace("Z", "+00:00"))
                        except ValueError:
                            continue
                        cache["entries"].append((entry_time, self._entry_cost(entry)))
                    cache["offset"] = f.tell()
                cache["mtime"] = st.st_mtime
            except OSError:
                return 0.0

        # Sum within window; prune anything older so the cache stays bounded.
        total = 0.0
        keep = []
        for ts, cost in cache["entries"]:
            if ts >= since:
                total += cost
                keep.append((ts, cost))
        cache["entries"] = keep
        return total

    def _entry_cost(self, entry):
        model = entry.get("model", "")
        input_tokens = entry.get("input_tokens", 0)
        output_tokens = entry.get("output_tokens", 0)
        cache_read = entry.get("cache_read_input_tokens", 0)
        cache_create = entry.get("cache_creation_input_tokens", 0)

        pricing = self._find_pricing(model)
        if pricing is None:
            return 0.0

        cost = (
            input_tokens  * pricing["input"]
            + output_tokens * pricing["output"]
            + cache_read    * pricing["cache_read"]
            + cache_create  * pricing["cache_write"]
        )
        return cost / 1_000_000

    def _find_pricing(self, model):
        for prefix in _MODEL_PRICING_PREFIXES:
            if model == prefix or model.startswith(prefix + "-"):
                return MODEL_PRICING[prefix]
        if model.startswith("claude-"):
            should_warn = False
            with self._lock:
                self._unknown_models.add(model)
                if model not in self._warned_models:
                    self._warned_models.add(model)
                    should_warn = True
            if should_warn:
                print(
                    f"\nUnrecognised Claude model '{model}' — session will finish but ddbya will then exit.\n"
                    f"Download the latest version:\n"
                    f"  curl -o ddbya https://raw.githubusercontent.com/giacecco/dolla-dolla-bill-y-all/main/ddbya",
                    file=sys.stderr,
                )
            return _DEFAULT_PRICING
        return None


def parse_args(argv):
    """Extract wrapper-specific flags, return (ollama_model_or_none, limit_usd_or_none, lookback_days_or_none, tags, remaining_args_for_claude)."""
    ollama_model = None
    limit_usd = None
    lookback_days = None
    tags = []
    claude_args = []
    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg in ("-o", "--ollama-model"):
            if ollama_model is not None:
                print("error: -o/--ollama-model given more than once", file=sys.stderr)
                sys.exit(1)
            if i + 1 >= len(argv):
                print("error: -o/--ollama-model requires a model name", file=sys.stderr)
                sys.exit(1)
            val = argv[i + 1]
            if val.startswith("-"):
                print(f"error: -o/--ollama-model value looks like a flag: {val!r}", file=sys.stderr)
                sys.exit(1)
            ollama_model = val
            i += 2
            continue
        elif arg in ("-l", "--limit"):
            if limit_usd is not None:
                print("error: -l/--limit given more than once", file=sys.stderr)
                sys.exit(1)
            if i + 1 >= len(argv):
                print("error: -l/--limit requires a USD amount", file=sys.stderr)
                sys.exit(1)
            try:
                limit_usd = float(argv[i + 1])
            except ValueError:
                print(f"error: invalid limit value: {argv[i + 1]!r}", file=sys.stderr)
                sys.exit(1)
            if limit_usd <= 0:
                print(f"error: limit must be positive: {limit_usd}", file=sys.stderr)
                sys.exit(1)
            i += 2
            continue
        elif arg == "--last":
            if lookback_days is not None:
                print("error: --last given more than once", file=sys.stderr)
                sys.exit(1)
            if i + 1 >= len(argv):
                print("error: --last requires a number of days", file=sys.stderr)
                sys.exit(1)
            try:
                lookback_days = int(argv[i + 1])
            except ValueError:
                print(f"error: invalid --last value: {argv[i + 1]!r}", file=sys.stderr)
                sys.exit(1)
            if lookback_days <= 0:
                print(f"error: --last must be positive: {lookback_days}", file=sys.stderr)
                sys.exit(1)
            i += 2
            continue
        elif arg in ("-t", "--tag"):
            if i + 1 >= len(argv):
                print("error: -t/--tag requires a value", file=sys.stderr)
                sys.exit(1)
            tags.append(argv[i + 1])
            i += 2
            continue
        claude_args.append(arg)
        i += 1

    if limit_usd is not None and lookback_days is None:
        print("error: --limit requires --last <days>", file=sys.stderr)
        sys.exit(1)
    if lookback_days is not None and limit_usd is None:
        print("error: --last requires --limit <USD>", file=sys.stderr)
        sys.exit(1)
    if limit_usd is not None and ollama_model is not None:
        print("error: -l/--limit is not supported with -o/--ollama-model", file=sys.stderr)
        sys.exit(1)

    return ollama_model, limit_usd, lookback_days, tags, claude_args


# Claude CLI flags that consume the next argv token as their value. Used by
# is_programmatic_invocation to avoid misreading "-p"/"--print" when it appears
# as the value of a preceding flag (e.g. --model -p).
_CLAUDE_VALUE_FLAGS = frozenset({
    "--model",
    "--add-dir",
    "--allowedTools",
    "--disallowedTools",
    "--mcp-config",
    "--append-system-prompt",
    "--permission-mode",
    "--permission-prompt-tool",
    "--session-id",
    "--agents",
    "--setting-sources",
    "--input-format",
    "--output-format",
})


def is_programmatic_invocation(claude_args):
    """True if -p/--print appears as a flag (not as the value of another flag)."""
    skip_next = False
    for arg in claude_args:
        if skip_next:
            skip_next = False
            continue
        if arg in ("-p", "--print"):
            return True
        if arg in _CLAUDE_VALUE_FLAGS:
            skip_next = True
    return False


class TokenLogger:
    """Writes token usage to a project-local JSONL file and tracks session totals."""

    def __init__(self, log_path):
        self._log_path = Path(log_path)
        self._lock = threading.Lock()
        self.session_entries = []
        self._file = open(self._log_path, "a")

    def log(self, entry):
        entry = {**entry, "timestamp": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")}
        with self._lock:
            self.session_entries.append(entry)
            self._file.write(json.dumps(entry, sort_keys=True) + "\n")
            self._file.flush()

    def close(self):
        with self._lock:
            if self._file is not None and not self._file.closed:
                self._file.close()

    def summary(self):
        with self._lock:
            entries = list(self.session_entries)
        total_input = sum(e.get("input_tokens", 0) for e in entries)
        total_output = sum(e.get("output_tokens", 0) for e in entries)
        total_cache_read = sum(e.get("cache_read_input_tokens", 0) for e in entries)
        total_cache_create = sum(e.get("cache_creation_input_tokens", 0) for e in entries)
        return total_input, total_output, total_cache_read, total_cache_create, len(entries)


class ReverseProxyHandler(http.server.BaseHTTPRequestHandler):
    """Handles incoming requests by forwarding them to the upstream Anthropic API."""

    # Set by ReverseProxy at server creation time
    upstream_scheme = "https"
    upstream_netloc = "api.anthropic.com"
    token_logger = None
    programmatic = False
    tags = None
    proxy = None

    # Suppress http.server's default request logging
    def log_message(self, format, *args):
        pass

    def _log_token_usage(self, model, stream, input_tokens, output_tokens,
                          cache_read=0, cache_create=0):
        entry = {
            "model": model,
            "stream": stream,
            "input_tokens": input_tokens,
            "output_tokens": output_tokens,
        }
        if self.programmatic:
            entry["programmatic"] = True
        if self.tags:
            entry["tags"] = list(self.tags)
        if cache_read:
            entry["cache_read_input_tokens"] = cache_read
        if cache_create:
            entry["cache_creation_input_tokens"] = cache_create
        self.token_logger.log(entry)

    def _refuse_budget_exceeded(self):
        """Reply with a synthetic Anthropic-style error so claude surfaces it cleanly."""
        content_length = int(self.headers.get("Content-Length", 0))
        if content_length:
            try:
                self.rfile.read(content_length)
            except OSError:
                pass
        body = json.dumps({
            "type": "error",
            "error": {
                "type": "overloaded_error",
                "message": "ddbya: budget limit exceeded; new requests are blocked.",
            },
        }).encode()
        try:
            self.send_response(429, "Too Many Requests")
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        except OSError:
            pass

    def _forward(self, method):
        if self.proxy is not None and self.proxy.budget_exceeded.is_set():
            self._refuse_budget_exceeded()
            return
        if self.proxy is not None:
            self.proxy.begin_request()
        try:
            self._do_forward(method)
        finally:
            if self.proxy is not None:
                self.proxy.end_request()

    def _do_forward(self, method):
        # Read the request body
        content_length = int(self.headers.get("Content-Length", 0))
        req_body = self.rfile.read(content_length) if content_length else b""

        # Forward to upstream
        if self.upstream_scheme == "https":
            conn = http.client.HTTPSConnection(self.upstream_netloc, timeout=300)
        else:
            conn = http.client.HTTPConnection(self.upstream_netloc, timeout=300)

        upstream_headers = {}
        for key, value in self.headers.items():
            low = key.lower()
            if low not in ("host", "connection", "proxy-connection"):
                upstream_headers[key] = value

        try:
            try:
                conn.request(method, self.path, body=req_body, headers=upstream_headers)
                resp = conn.getresponse()
            except OSError as exc:
                self.send_error(502, f"Bad Gateway: {exc}")
                return

            is_gzip = resp.getheader("Content-Encoding", "").lower() == "gzip"

            # Parse request body once; reuse parsed form downstream.
            req_data = {}
            if req_body:
                try:
                    req_data = json.loads(req_body)
                except json.JSONDecodeError:
                    pass
            is_streaming = req_data.get("stream", False)

            # Relay response status and headers. Never forward
            # Content-Encoding: gzip — the proxy handles decompression
            # and the client should not try to decompress twice.
            self.send_response(resp.status, resp.reason)
            for key, value in resp.getheaders():
                low = key.lower()
                if low in ("transfer-encoding", "connection", "keep-alive"):
                    continue
                if low == "content-encoding" and value.lower() == "gzip":
                    continue
                # Drop Content-Length when we will not deliver the exact same
                # byte count: gzip is decompressed by us, and streaming responses
                # are relayed chunk-by-chunk so the original length no longer
                # matches what the client receives.
                if low == "content-length" and (is_gzip or is_streaming):
                    continue
                self.send_header(key, value)
            self.end_headers()

            if is_streaming:
                self._relay_stream(resp, req_data, is_gzip)
            else:
                resp_body = resp.read()
                if is_gzip:
                    resp_body = gzip.decompress(resp_body)
                self.wfile.write(resp_body)
                self._extract_usage_nonstream(resp_body)
        finally:
            conn.close()

    def _relay_stream(self, resp, req_data, is_gzip):
        """Relay SSE events chunk by chunk, parsing usage inline without buffering the full body."""
        if is_gzip:
            decompressor = zlib.decompressobj(zlib.MAX_WBITS | 16)

        req_model = req_data.get("model", "")
        best_input = best_output = cache_read = cache_create = 0
        best_model = req_model

        def process_line(text):
            nonlocal best_input, best_output, best_model, cache_read, cache_create
            if not text.startswith("data: "):
                return
            try:
                event = json.loads(text[6:])
            except json.JSONDecodeError:
                return
            event_type = event.get("type", "")
            if event_type == "message_start":
                msg = event.get("message", {})
                usage = msg.get("usage", {})
                if usage.get("input_tokens", 0) > 0:
                    best_input = usage["input_tokens"]
                cache_read = usage.get("cache_read_input_tokens", 0)
                cache_create = usage.get("cache_creation_input_tokens", 0)
                if msg.get("model"):
                    best_model = msg["model"]
            elif event_type == "message_delta":
                usage = event.get("usage", {})
                if usage.get("output_tokens", 0) > 0:
                    best_output = usage["output_tokens"]
                if event.get("model"):
                    best_model = event["model"]
            elif event_type == "message_stop":
                usage = event.get("usage", {})
                if usage:
                    if usage.get("input_tokens", 0) > 0:
                        best_input = usage["input_tokens"]
                    if usage.get("output_tokens", 0) > 0:
                        best_output = usage["output_tokens"]
                if event.get("model"):
                    best_model = event["model"]

        # Track whether the client is still reading. A disconnect mid-stream
        # should not crash the handler; keep parsing usage from upstream so the
        # session totals are still logged.
        client_alive = True
        pending = b""
        while True:
            chunk = resp.read(4096)
            if not chunk:
                break
            if is_gzip:
                chunk = decompressor.decompress(chunk)
            if client_alive:
                try:
                    self.wfile.write(chunk)
                    self.wfile.flush()
                except OSError:
                    client_alive = False
            pending += chunk
            while b"\n" in pending:
                raw_line, pending = pending.split(b"\n", 1)
                process_line(raw_line.decode("utf-8", errors="replace").rstrip("\r"))

        if is_gzip:
            tail = decompressor.flush()
            if tail:
                if client_alive:
                    try:
                        self.wfile.write(tail)
                        self.wfile.flush()
                    except OSError:
                        client_alive = False
                pending += tail

        if pending:
            process_line(pending.decode("utf-8", errors="replace").rstrip("\r"))

        if best_input > 0 or best_output > 0:
            self._log_token_usage(
                model=best_model,
                stream=True,
                input_tokens=best_input,
                output_tokens=best_output,
                cache_read=cache_read,
                cache_create=cache_create,
            )

    def _extract_usage_nonstream(self, resp_body):
        try:
            data = json.loads(resp_body)
            usage = data.get("usage")
            if not usage:
                return
            self._log_token_usage(
                model=data.get("model", ""),
                stream=False,
                input_tokens=usage.get("input_tokens", 0),
                output_tokens=usage.get("output_tokens", 0),
                cache_read=usage.get("cache_read_input_tokens", 0),
                cache_create=usage.get("cache_creation_input_tokens", 0),
            )
        except json.JSONDecodeError:
            pass

    # Dispatch every HTTP method to the forwarder
    def do_GET(self): self._forward("GET")
    def do_POST(self): self._forward("POST")
    def do_PUT(self): self._forward("PUT")
    def do_DELETE(self): self._forward("DELETE")
    def do_PATCH(self): self._forward("PATCH")
    def do_OPTIONS(self): self._forward("OPTIONS")
    def do_HEAD(self): self._forward("HEAD")


class ReverseProxy:
    """Manages the lifecycle of the reverse proxy HTTP server."""

    def __init__(self, upstream_url, programmatic=False, tags=None):
        parsed = urllib.parse.urlparse(upstream_url)
        if parsed.scheme and parsed.netloc:
            self.upstream_scheme = parsed.scheme
            self.upstream_netloc = parsed.netloc
        else:
            default = urllib.parse.urlparse(DEFAULT_UPSTREAM)
            self.upstream_scheme = default.scheme
            self.upstream_netloc = default.netloc

        self.programmatic = programmatic
        self.tags = tags or []
        self.token_logger = TokenLogger(TOKEN_LOG_FILE)
        self._server = None
        self._thread = None

        # Coordinates graceful shutdown when a budget limit is exceeded:
        # budget_exceeded → handler refuses new requests; idle Event allows
        # the watchdog to wait until in-flight requests have drained.
        self.budget_exceeded = threading.Event()
        self._in_flight = 0
        self._in_flight_lock = threading.Lock()
        self._idle = threading.Event()
        self._idle.set()

    def begin_request(self):
        with self._in_flight_lock:
            self._in_flight += 1
            self._idle.clear()

    def end_request(self):
        with self._in_flight_lock:
            self._in_flight -= 1
            if self._in_flight == 0:
                self._idle.set()

    def wait_idle(self):
        self._idle.wait()

    @property
    def is_idle(self):
        return self._idle.is_set()

    @property
    def port(self):
        return self._server.server_address[1] if self._server else None

    def start(self):
        # Bind to port 0 to let the OS pick a free port
        handler = self._build_handler()
        self._server = http.server.ThreadingHTTPServer(("127.0.0.1", 0), handler)
        self._thread = threading.Thread(target=self._server.serve_forever, daemon=True)
        self._thread.start()

    def stop(self):
        if self._server:
            self._server.shutdown()

    def _build_handler(self):
        proxy = self

        class BoundHandler(ReverseProxyHandler):
            pass

        BoundHandler.token_logger = proxy.token_logger
        BoundHandler.upstream_scheme = proxy.upstream_scheme
        BoundHandler.upstream_netloc = proxy.upstream_netloc
        BoundHandler.programmatic = proxy.programmatic
        BoundHandler.tags = proxy.tags
        BoundHandler.proxy = proxy
        return BoundHandler


def format_summary(input_tokens, output_tokens, cache_read, cache_create, request_count):
    lines = [
        "\nSession token usage:",
        f"  Requests:     {request_count}",
        f"  Input:        {input_tokens:,} tokens",
        f"  Output:       {output_tokens:,} tokens",
    ]
    if cache_read:
        lines.append(f"  Cache read:   {cache_read:,} tokens")
    if cache_create:
        lines.append(f"  Cache write:  {cache_create:,} tokens")
    total = input_tokens + output_tokens + cache_read + cache_create
    lines.append(f"  Total:        {total:,} tokens")
    return "\n".join(lines)


def main():
    ollama_model, limit_usd, lookback_days, tags, claude_args = parse_args(sys.argv[1:])

    if ollama_model:
        ollama_host = os.environ.get("OLLAMA_HOST", OLLAMA_DEFAULT_HOST)
        upstream = f"http://{ollama_host}"
        claude_args = ["--model", ollama_model] + claude_args
    else:
        upstream = os.environ.get("ANTHROPIC_BASE_URL", DEFAULT_UPSTREAM)

    programmatic = is_programmatic_invocation(claude_args)

    proxy = ReverseProxy(upstream, programmatic=programmatic, tags=tags)
    proxy.start()

    budget_checker = None
    if limit_usd is not None:
        budget_checker = BudgetChecker(
            limit_usd, lookback_days, Path.cwd(),
            on_exceeded=proxy.budget_exceeded.set,
            is_idle=lambda: proxy.is_idle,
        )
        budget_checker.start()
        budget_checker.wait_first_check()

        unknown = budget_checker.unknown_models
        if unknown:
            print(
                f"\nUnrecognised model(s) in recent token usage: {', '.join(unknown)}\n"
                f"Your copy of ddbya may be out of date. Download the latest version:\n"
                f"  curl -o ddbya https://raw.githubusercontent.com/giacecco/dolla-dolla-bill-y-all/main/ddbya",
                file=sys.stderr,
            )
            proxy.stop()
            budget_checker.stop()
            sys.exit(1)

        if budget_checker.limit_exceeded:
            print(
                f"Budget limit already exceeded: "
                f"${budget_checker.current_cost:.2f} / ${limit_usd:.2f} "
                f"in the last {lookback_days} day(s).",
                file=sys.stderr,
            )
            proxy.stop()
            budget_checker.stop()
            sys.exit(1)

    env = os.environ.copy()
    env["ANTHROPIC_BASE_URL"] = f"http://127.0.0.1:{proxy.port}"
    if ollama_model:
        env["ANTHROPIC_AUTH_TOKEN"] = "ollama"
        env.pop("ANTHROPIC_API_KEY", None)
    else:
        # Clear Ollama auth so Claude Code uses its normal keychain/OAuth login
        if env.get("ANTHROPIC_AUTH_TOKEN") == "ollama":
            env.pop("ANTHROPIC_AUTH_TOKEN", None)
            env.pop("ANTHROPIC_API_KEY", None)

    # Restore default SIGINT behaviour so Ctrl+C is forwarded to claude naturally.
    # Python installs its own SIGINT handler that raises KeyboardInterrupt;
    # restoring SIG_DFL lets the claude subprocess receive the signal directly.
    original_sigint = signal.signal(signal.SIGINT, signal.SIG_DFL)

    try:
        proc = subprocess.Popen(
            ["claude"] + claude_args,
            env=env,
            stdin=sys.stdin,
            stdout=sys.stdout,
            stderr=sys.stderr,
        )
    except FileNotFoundError:
        signal.signal(signal.SIGINT, original_sigint)
        if budget_checker:
            budget_checker.stop()
        proxy.stop()
        proxy.token_logger.close()
        print(
            "error: 'claude' executable not found on PATH. "
            "Install Claude Code (https://claude.com/claude-code) and try again.",
            file=sys.stderr,
        )
        sys.exit(127)

    if budget_checker is not None:
        def _watchdog():
            proxy.budget_exceeded.wait()
            print(
                f"\nBudget limit exceeded "
                f"(${budget_checker.current_cost:.2f} / ${limit_usd:.2f} "
                f"in the last {lookback_days} day(s)). "
                f"New API calls will be refused; the session will end once "
                f"in-flight requests have completed.",
                file=sys.stderr,
            )
            proxy.wait_idle()
            proc.terminate()
            try:
                proc.wait(timeout=30)
            except subprocess.TimeoutExpired:
                print(
                    "claude did not exit within 30s of SIGTERM; sending SIGKILL.",
                    file=sys.stderr,
                )
                proc.kill()

        threading.Thread(target=_watchdog, daemon=True).start()

    try:
        exit_code = proc.wait()
    finally:
        signal.signal(signal.SIGINT, original_sigint)
        if budget_checker:
            budget_checker.stop()
        proxy.stop()
        proxy.token_logger.close()

    input_tokens, output_tokens, cache_read, cache_create, request_count = proxy.token_logger.summary()
    if request_count > 0:
        print(format_summary(input_tokens, output_tokens, cache_read, cache_create, request_count), file=sys.stderr)

    if budget_checker:
        print(
            f"\nTotal spend (last {lookback_days} day(s), all projects): "
            f"${budget_checker.current_cost:.2f} / ${limit_usd:.2f}",
            file=sys.stderr,
        )
        unknown = budget_checker.unknown_models
        if unknown:
            print(
                f"\nUnrecognised model(s) encountered during session: {', '.join(unknown)}\n"
                f"Your copy of ddbya may be out of date. Download the latest version:\n"
                f"  curl -o ddbya https://raw.githubusercontent.com/giacecco/dolla-dolla-bill-y-all/main/ddbya",
                file=sys.stderr,
            )
            sys.exit(1)
        if budget_checker.limit_exceeded:
            print(
                f"Budget limit was exceeded; further ddbya launches will be "
                f"refused until spend over the last {lookback_days} day(s) "
                f"drops below ${limit_usd:.2f}.",
                file=sys.stderr,
            )

    sys.exit(exit_code)


if __name__ == "__main__":
    main()
