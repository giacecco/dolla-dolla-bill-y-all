#!/usr/bin/env python3
"""
Aggregate token usage across multiple Claude Code projects.

Usage:
    ddbya-report ROOT_FOLDER [--last N] [--from YYYY-MM-DD] [--to YYYY-MM-DD] [-t <tag> ...]

Zero dependencies — Python 3 standard library only.
"""

import sys
import json
import importlib.util
import importlib.machinery
from datetime import datetime, timezone, timedelta
from collections import defaultdict
from pathlib import Path


def _load_pricing_from_ddbya():
    """Pricing lives in ddbya; load it from the sibling file so the two scripts can't drift."""
    ddbya_path = Path(__file__).resolve().parent / "ddbya"
    if not ddbya_path.is_file():
        sys.exit(
            f"ddbya-report: cannot find sibling 'ddbya' at {ddbya_path}.\n"
            f"ddbya-report sources pricing from ddbya; install them in the same directory."
        )
    loader = importlib.machinery.SourceFileLoader("_ddbya_pricing", str(ddbya_path))
    spec = importlib.util.spec_from_loader("_ddbya_pricing", loader)
    module = importlib.util.module_from_spec(spec)
    loader.exec_module(module)
    return module.MODEL_PRICING, module._DEFAULT_PRICING, module._MODEL_PRICING_PREFIXES


MODEL_PRICING, _DEFAULT_PRICING, _MODEL_PRICING_PREFIXES = _load_pricing_from_ddbya()


def parse_args():
    args = sys.argv[1:]
    if not args:
        sys.exit("Usage: ddbya-report ROOT_FOLDER [--last N] [--from YYYY-MM-DD] [--to YYYY-MM-DD]")

    root = Path(args[0])
    if not root.is_dir():
        sys.exit(f"Not a directory: {root}")

    params = {"root": root, "last": None, "from": None, "to": None, "tags": []}

    i = 1
    while i < len(args):
        if args[i] == "--last" and i + 1 < len(args):
            try:
                params["last"] = int(args[i + 1])
            except ValueError:
                sys.exit(f"Invalid --last value: {args[i + 1]}")
            i += 2
        elif args[i] == "--from" and i + 1 < len(args):
            try:
                datetime.strptime(args[i + 1], "%Y-%m-%d")
            except ValueError:
                sys.exit(f"Invalid --from date (expected YYYY-MM-DD): {args[i + 1]}")
            params["from"] = args[i + 1]
            i += 2
        elif args[i] == "--to" and i + 1 < len(args):
            try:
                datetime.strptime(args[i + 1], "%Y-%m-%d")
            except ValueError:
                sys.exit(f"Invalid --to date (expected YYYY-MM-DD): {args[i + 1]}")
            params["to"] = args[i + 1]
            i += 2
        elif args[i] in ("-t", "--tag") and i + 1 < len(args):
            params["tags"].append(args[i + 1])
            i += 2
        else:
            sys.exit(f"Unknown argument: {args[i]}")

    return params


def resolve_window(params):
    now = datetime.now(timezone.utc)

    if params["to"]:
        to_date = datetime.strptime(params["to"], "%Y-%m-%d").replace(tzinfo=timezone.utc) + timedelta(days=1)
    else:
        to_date = now

    if params["from"]:
        from_date = datetime.strptime(params["from"], "%Y-%m-%d").replace(tzinfo=timezone.utc)
    elif params["last"] is not None:
        from_date = now - timedelta(days=params["last"])
    else:
        from_date = now - timedelta(days=7)

    return from_date, to_date


def find_pricing(model):
    for prefix in _MODEL_PRICING_PREFIXES:
        if model == prefix or model.startswith(prefix + "-"):
            return MODEL_PRICING[prefix]
    if model.startswith("claude-"):
        return _DEFAULT_PRICING
    return None


def entry_cost(model, input_tokens, output_tokens, cache_read, cache_create):
    pricing = find_pricing(model)
    if pricing is None:
        return 0.0
    return (
        input_tokens  * pricing["input"]
        + output_tokens * pricing["output"]
        + cache_read    * pricing["cache_read"]
        + cache_create  * pricing["cache_write"]
    ) / 1_000_000


def collect_entries(root, from_date, to_date, tag_filters=None):
    direct = root / "token-usage.jsonl"
    if direct.exists():
        paths = [direct]
    else:
        paths = sorted(
            p for p in (child / "token-usage.jsonl" for child in root.iterdir() if child.is_dir())
            if p.exists()
        )

    usage = []
    for jsonl_path in paths:
        project = jsonl_path.parent.name or jsonl_path.parent.resolve().name
        with open(jsonl_path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                    ts = datetime.strptime(entry["timestamp"], "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
                except (json.JSONDecodeError, KeyError, ValueError):
                    continue
                if not (from_date <= ts < to_date):
                    continue

                model = entry.get("model", "unknown")
                programmatic = "yes" if entry.get("programmatic") else "no"
                entry_tags = entry.get("tags")
                if isinstance(entry_tags, list):
                    entry_tags = sorted(entry_tags, key=str.lower)
                else:
                    entry_tags = []
                if tag_filters and not set(tag_filters).issubset(entry_tags):
                    continue
                tag_str = ", ".join(entry_tags) if entry_tags else ""
                inp = entry.get("input_tokens", 0)
                out = entry.get("output_tokens", 0)
                cr = entry.get("cache_read_input_tokens", 0)
                cc = entry.get("cache_creation_input_tokens", 0)
                usage.append({
                    "project": project,
                    "model": model,
                    "programmatic": programmatic,
                    "tags": tag_str,
                    "input_tokens": inp,
                    "output_tokens": out,
                    "cache_read": cr,
                    "cache_create": cc,
                    "cost": entry_cost(model, inp, out, cr, cc),
                    "requests": 1,
                })
    return usage


def aggregate(entries):
    key = lambda e: (e["project"], e["model"], e["programmatic"], e["tags"])
    groups = defaultdict(lambda: {"input_tokens": 0, "output_tokens": 0, "cache_read": 0, "cache_create": 0, "cost": 0.0, "requests": 0})

    for e in entries:
        k = key(e)
        g = groups[k]
        g["input_tokens"] += e["input_tokens"]
        g["output_tokens"] += e["output_tokens"]
        g["cache_read"] += e["cache_read"]
        g["cache_create"] += e["cache_create"]
        g["cost"] += e["cost"]
        g["requests"] += e["requests"]

    result = []
    for (project, model, programmatic, tag_str), g in sorted(groups.items()):
        result.append({
            "project": project,
            "model": model,
            "programmatic": programmatic,
            "tags": tag_str,
            **g,
        })
    return result


def fmt(n):
    if n == 0:
        return "-"
    return f"{n:,}"


def fmt_cost(n):
    if n == 0:
        return "-"
    return f"${n:,.2f}"


def _col_widths(rows):
    """Compute column widths from data so long values never silently truncate."""
    extra_labels = ["(subtotal)", "TOTAL"]

    def lw(header, values):
        return -(max(len(header), max((len(v) for v in values), default=0)))

    def rw(header, values):
        return max(len(header), max((len(v) for v in values), default=0))

    show_tags = any(r.get("tags") for r in rows)

    projects = [r["project"] for r in rows] + extra_labels
    models = [r["model"] for r in rows] + [""]
    programmatic = [r["programmatic"] for r in rows] + [""]
    all_tags = [r["tags"] for r in rows] + [""]
    reqs = [fmt(r["requests"]) for r in rows]
    inputs = [fmt(r["input_tokens"]) for r in rows]
    totals = [fmt(r["input_tokens"] + r["cache_read"] + r["cache_create"]) for r in rows]
    outputs = [fmt(r["output_tokens"]) for r in rows]
    reads = [fmt(r["cache_read"]) for r in rows]
    creates = [fmt(r["cache_create"]) for r in rows]
    costs = [fmt_cost(r["cost"]) for r in rows]

    cols = [
        ("Project",       lw("Project", projects)),
        ("Model",         lw("Model", models)),
        ("Programmatic",  lw("Programmatic", programmatic)),
        ("Reqs",          rw("Reqs", reqs)),
        ("Input (base)",  rw("Input (base)", inputs)),
        ("Cache Read",    rw("Cache Read", reads)),
        ("Cache Create",  rw("Cache Create", creates)),
        ("Total Input",   rw("Total Input", totals)),
        ("Output Tokens", rw("Output Tokens", outputs)),
        ("Cost (USD)",    rw("Cost (USD)", costs)),
    ]
    if show_tags:
        cols.append(("Tags", lw("Tags", all_tags)))
    return cols, show_tags


def _build_row(values, cols):
    """Build a table row from a list of (value, col_index) pairs."""
    parts = []
    for value, ci in values:
        _, width = cols[ci]
        if width < 0:
            parts.append(f"{value:<{-width}}")
        else:
            parts.append(f"{value:>{width}}")
    return "  ".join(parts)


def report(rows, from_date, to_date):
    to_display = to_date - timedelta(days=1)
    if (to_display - from_date).days < 1:
        header = f"Token Usage Report — {from_date.strftime('%Y-%m-%d')}"
    else:
        header = f"Token Usage Report — {from_date.strftime('%Y-%m-%d')} to {to_display.strftime('%Y-%m-%d')}"
    print(header)
    print()

    if not rows:
        print("No usage data found.")
        return

    cols, show_tags = _col_widths(rows)

    header_line = "  ".join(f"{label:<{-width}}" if width < 0 else f"{label:>{width}}" for label, width in cols)
    print(header_line)
    print("  ".join("─" * abs(w) for _, w in cols))

    # Column indices. Tags (when present) is always last.
    _ci_project = 0
    _ci_model = 1
    _ci_prog = 2
    _ci_reqs = 3
    _ci_input = 4
    _ci_read = 5
    _ci_create = 6
    _ci_tot_inp = 7
    _ci_output = 8
    _ci_cost = 9
    _ci_tags = 10

    _blank = [("", _ci_model), ("", _ci_prog)]

    last_project = None
    proj_input = proj_output = proj_read = proj_create = proj_reqs = 0
    proj_cost = 0.0
    tot_input = tot_output = tot_read = tot_create = tot_reqs = 0
    tot_cost = 0.0

    def flush_project():
        nonlocal proj_input, proj_output, proj_read, proj_create, proj_reqs, proj_cost
        if last_project is not None and proj_reqs:
            vals = [("(subtotal)", _ci_project)] + _blank + [
                (fmt(proj_reqs), _ci_reqs),
                (fmt(proj_input), _ci_input),
                (fmt(proj_read), _ci_read),
                (fmt(proj_create), _ci_create),
                (fmt(proj_input + proj_read + proj_create), _ci_tot_inp),
                (fmt(proj_output), _ci_output),
                (fmt_cost(proj_cost), _ci_cost),
            ]
            print(_build_row(vals, cols))
            print()
        proj_input = proj_output = proj_read = proj_create = proj_reqs = 0
        proj_cost = 0.0

    for r in rows:
        if r["project"] != last_project:
            flush_project()
            last_project = r["project"]

        vals = [
            (r["project"], _ci_project),
            (r["model"], _ci_model),
            (r["programmatic"], _ci_prog),
            (fmt(r["requests"]), _ci_reqs),
            (fmt(r["input_tokens"]), _ci_input),
            (fmt(r["cache_read"]), _ci_read),
            (fmt(r["cache_create"]), _ci_create),
            (fmt(r["input_tokens"] + r["cache_read"] + r["cache_create"]), _ci_tot_inp),
            (fmt(r["output_tokens"]), _ci_output),
            (fmt_cost(r["cost"]), _ci_cost),
        ]
        if show_tags:
            vals.append((r["tags"], _ci_tags))
        print(_build_row(vals, cols))

        proj_input += r["input_tokens"]
        proj_output += r["output_tokens"]
        proj_read += r["cache_read"]
        proj_create += r["cache_create"]
        proj_reqs += r["requests"]
        proj_cost += r["cost"]

        tot_input += r["input_tokens"]
        tot_output += r["output_tokens"]
        tot_read += r["cache_read"]
        tot_create += r["cache_create"]
        tot_reqs += r["requests"]
        tot_cost += r["cost"]

    flush_project()

    total_vals = [("TOTAL", _ci_project)] + _blank + [
        (fmt(tot_reqs), _ci_reqs),
        (fmt(tot_input), _ci_input),
        (fmt(tot_read), _ci_read),
        (fmt(tot_create), _ci_create),
        (fmt(tot_input + tot_read + tot_create), _ci_tot_inp),
        (fmt(tot_output), _ci_output),
        (fmt_cost(tot_cost), _ci_cost),
    ]
    print(_build_row(total_vals, cols))


def main():
    params = parse_args()
    from_date, to_date = resolve_window(params)
    entries = collect_entries(params["root"], from_date, to_date, tag_filters=params["tags"])
    rows = aggregate(entries)
    report(rows, from_date, to_date)


if __name__ == "__main__":
    main()
