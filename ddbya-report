#!/usr/bin/env python3
"""
Aggregate token usage across multiple Claude Code projects.

Usage:
    ddbya-report ROOT_FOLDER [--last N | --today] [--from YYYY-MM-DD] [--to YYYY-MM-DD] [-t <tag> ...] [--json | --csv]
    ddbya-report ROOT_FOLDER -t <filter> -t +<tag>   add tags to matching entries
    ddbya-report ROOT_FOLDER -t <filter> -t -<tag>   remove tags from matching entries

Includes all data by default. Pass --last, --from, or --to to filter by date.
Retagging with -t +/- modifies .ddbya.d/usage-*.ddbya files in-place.

Zero dependencies — Python 3 standard library only.
"""

import sys
import os
import csv
import json
import re
from datetime import datetime, timezone, timedelta
from collections import defaultdict
from pathlib import Path

DDBYA_DIR = ".ddbya.d"
USAGE_GLOB = "usage-*.ddbya"


def parse_args():
    args = sys.argv[1:]
    if not args:
        sys.exit("Usage: ddbya-report ROOT_FOLDER [--last N | --today] [--from YYYY-MM-DD] [--to YYYY-MM-DD] [-t <tag> ...] [--json | --csv]\n"
                 "       ddbya-report ROOT_FOLDER -t +/-TAG  (retag, in-place)")

    root = Path(args[0])
    if not root.is_dir():
        sys.exit(f"Not a directory: {root}")

    params = {"root": root, "last": None, "from": None, "to": None, "today": False,
              "tags": [], "add_tags": [], "remove_tags": [], "json": False, "csv": False}

    i = 1
    while i < len(args):
        if args[i] == "--last" and i + 1 < len(args):
            try:
                params["last"] = int(args[i + 1])
            except ValueError:
                sys.exit(f"Invalid --last value: {args[i + 1]}")
            i += 2
        elif args[i] == "--from" and i + 1 < len(args):
            try:
                datetime.strptime(args[i + 1], "%Y-%m-%d")
            except ValueError:
                sys.exit(f"Invalid --from date (expected YYYY-MM-DD): {args[i + 1]}")
            params["from"] = args[i + 1]
            i += 2
        elif args[i] == "--to" and i + 1 < len(args):
            try:
                datetime.strptime(args[i + 1], "%Y-%m-%d")
            except ValueError:
                sys.exit(f"Invalid --to date (expected YYYY-MM-DD): {args[i + 1]}")
            params["to"] = args[i + 1]
            i += 2
        elif args[i] == "--today":
            params["today"] = True
            i += 1
        elif args[i] in ("-t", "--tag"):
            if i + 1 >= len(args):
                sys.exit("error: -t/--tag requires a value")
            val = args[i + 1]
            if val.startswith("+") and not (val.startswith("/") and val.endswith("/")):
                tag = val[1:]
                if not tag:
                    sys.exit("error: -t/+ requires a tag name")
                params["add_tags"].append(tag)
            elif val.startswith("-") and not (val.startswith("/") and val.endswith("/")):
                tag = val[1:]
                if not tag:
                    sys.exit("error: -t/- requires a tag name")
                params["remove_tags"].append(tag)
            else:
                params["tags"].append(val)
            i += 2
        elif args[i] == "--json":
            params["json"] = True
            i += 1
        elif args[i] == "--csv":
            params["csv"] = True
            i += 1
        else:
            sys.exit(f"Unknown argument: {args[i]}")

    if params["today"] and (params["last"] is not None or params["from"] or params["to"]):
        sys.exit("error: --today cannot be combined with --last, --from, or --to")
    if params["last"] is not None and (params["from"] or params["to"]):
        sys.exit("error: --last cannot be combined with --from or --to")
    if params["json"] and params["csv"]:
        sys.exit("error: --json and --csv are mutually exclusive")
    if (params["add_tags"] or params["remove_tags"]) and (params["json"] or params["csv"]):
        sys.exit("error: retagging (-t +/-) cannot be combined with --json or --csv")

    return params


def resolve_window(params):
    now = datetime.now(timezone.utc)

    if params["today"]:
        today = now.replace(hour=0, minute=0, second=0, microsecond=0)
        return today, today + timedelta(days=1)

    if params["to"]:
        to_date = datetime.strptime(params["to"], "%Y-%m-%d").replace(tzinfo=timezone.utc) + timedelta(days=1)
    else:
        to_date = now

    if params["from"]:
        from_date = datetime.strptime(params["from"], "%Y-%m-%d").replace(tzinfo=timezone.utc)
    elif params["last"] is not None:
        from_date = now - timedelta(days=params["last"])
    else:
        from_date = None

    return from_date, to_date


def _match_tag(pattern, tag):
    """If /pattern/, treat as regex; otherwise literal exact match."""
    if pattern.startswith("/") and pattern.endswith("/") and len(pattern) > 2:
        return re.search(pattern[1:-1], tag)
    return pattern == tag


def _discover_usage_paths(root):
    """Yield (jsonl_path, project_dir) pairs for all usage files under root.

    Checks .ddbya.d/usage-*.ddbya (new layout) and falls back to
    .token-usage.ddbya (legacy) so projects not yet migrated still work.
    """
    direct_dir = root / ".ddbya.d"
    usage_files = sorted(direct_dir.glob("usage-*.ddbya")) if direct_dir.is_dir() else []
    if usage_files:
        for p in usage_files:
            yield p, root
    else:
        for p in sorted(root.rglob(".ddbya.d/usage-*.ddbya")):
            yield p, p.parent.parent

    # Legacy fallback: pick up any .token-usage.ddbya not yet migrated.
    legacy = root / ".token-usage.ddbya"
    if legacy.exists():
        yield legacy, root
    for p in sorted(root.rglob(".token-usage.ddbya")):
        if p != root / ".token-usage.ddbya":
            yield p, p.parent


def collect_entries(root, from_date, to_date, tag_filters=None):
    usage = []
    for jsonl_path, project_dir in _discover_usage_paths(root):
        if project_dir == root:
            project = root.name or root.resolve().name
        else:
            project = project_dir.relative_to(root).parts[0]
        try:
            fh = open(jsonl_path, encoding="utf-8")
        except OSError:
            continue
        with fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                    ts = datetime.strptime(entry["timestamp"], "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
                except (json.JSONDecodeError, KeyError, ValueError):
                    continue
                if from_date is not None and ts < from_date:
                    continue
                if ts >= to_date:
                    continue

                programmatic = "yes" if entry.get("programmatic") else "no"
                entry_tags = entry.get("tags")
                if isinstance(entry_tags, list):
                    entry_tags = sorted(entry_tags, key=str.lower)
                else:
                    entry_tags = []
                if tag_filters and not all(
                    any(_match_tag(pat, tag) for tag in entry_tags)
                    for pat in tag_filters
                ):
                    continue
                usage.append({
                    "project": project,
                    "programmatic": programmatic,
                    "tags": entry_tags,
                    "input_tokens": entry.get("input_tokens", 0),
                    "output_tokens": entry.get("output_tokens", 0),
                    "cache_read": entry.get("cache_read_input_tokens", 0),
                    "cache_create": entry.get("cache_creation_input_tokens", 0),
                    "requests": 1,
                })
    return usage


def retag(root, from_date, to_date, tag_filters, add_tags, remove_tags):
    """Modify tags in .ddbya.d/usage-*.ddbya files in-place.

    Returns (modified_entries, modified_files).
    """
    paths = [p for p, _ in _discover_usage_paths(root)]

    total_modified = 0
    files_modified = 0

    for jsonl_path in paths:
        modified = False
        lines = []
        with open(jsonl_path, encoding="utf-8") as f:
            for line in f:
                stripped = line.strip()
                if not stripped:
                    lines.append(line)
                    continue
                try:
                    entry = json.loads(stripped)
                    ts = datetime.strptime(entry["timestamp"], "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
                except (json.JSONDecodeError, KeyError, ValueError):
                    lines.append(line)
                    continue

                if from_date is not None and ts < from_date:
                    lines.append(line)
                    continue
                if ts >= to_date:
                    lines.append(line)
                    continue

                entry_tags = entry.get("tags")
                had_tags = isinstance(entry_tags, list)
                if had_tags:
                    entry_tags = sorted(entry_tags, key=str.lower)
                else:
                    entry_tags = []

                if tag_filters and not all(
                    any(_match_tag(pat, tag) for tag in entry_tags)
                    for pat in tag_filters
                ):
                    lines.append(line)
                    continue

                before = list(entry_tags)

                for t in add_tags:
                    if t not in entry_tags:
                        entry_tags.append(t)

                entry_tags = [t for t in entry_tags if not any(
                    _match_tag(pat, t) for pat in remove_tags
                )]

                if entry_tags == before:
                    lines.append(line)
                    continue

                if entry_tags:
                    entry["tags"] = entry_tags
                elif "tags" in entry:
                    del entry["tags"]
                lines.append(json.dumps(entry, sort_keys=True) + "\n")
                total_modified += 1
                modified = True

        if modified:
            tmp_path = jsonl_path.with_name(jsonl_path.name + ".tmp")
            with open(tmp_path, "w", encoding="utf-8") as f:
                f.writelines(lines)
            os.replace(tmp_path, jsonl_path)
            files_modified += 1

    return total_modified, files_modified


def aggregate(entries):
    key = lambda e: (e["project"], e["programmatic"], tuple(e["tags"]))
    groups = defaultdict(lambda: {"input_tokens": 0, "output_tokens": 0, "cache_read": 0, "cache_create": 0, "requests": 0})

    for e in entries:
        k = key(e)
        g = groups[k]
        g["input_tokens"] += e["input_tokens"]
        g["output_tokens"] += e["output_tokens"]
        g["cache_read"] += e["cache_read"]
        g["cache_create"] += e["cache_create"]
        g["requests"] += e["requests"]

    result = []
    for (project, programmatic, tags_tuple), g in sorted(groups.items()):
        result.append({
            "project": project,
            "programmatic": programmatic,
            "tags": list(tags_tuple),
            **g,
        })
    return result


def fmt(n):
    if n == 0:
        return "-"
    return f"{n:,}"


def _col_widths(rows):
    """Compute column widths from data so long values never silently truncate."""
    extra_labels = ["(subtotal)", "TOTAL"]

    # lw returns a negative width (left-aligned); rw returns positive (right-aligned).
    # _build_row checks the sign to choose the format spec.
    def lw(header, values):
        return -(max(len(header), max((len(v) for v in values), default=0)))

    def rw(header, values):
        return max(len(header), max((len(v) for v in values), default=0))

    show_tags = any(r.get("tags") for r in rows)
    _join = lambda t: " | ".join(t) if t else ""

    projects = [r["project"] for r in rows] + extra_labels
    programmatic = [r["programmatic"] for r in rows] + [""]
    all_tags = [_join(r["tags"]) for r in rows] + [""]
    reqs = [fmt(r["requests"]) for r in rows]
    inputs = [fmt(r["input_tokens"]) for r in rows]
    totals = [fmt(r["input_tokens"] + r["cache_read"] + r["cache_create"]) for r in rows]
    outputs = [fmt(r["output_tokens"]) for r in rows]
    reads = [fmt(r["cache_read"]) for r in rows]
    creates = [fmt(r["cache_create"]) for r in rows]

    cols = [
        ("Project",       lw("Project", projects)),
        ("Programmatic",  lw("Programmatic", programmatic)),
        ("Reqs",          rw("Reqs", reqs)),
        ("Input (base)",  rw("Input (base)", inputs)),
        ("Cache Read",    rw("Cache Read", reads)),
        ("Cache Create",  rw("Cache Create", creates)),
        ("Total Input",   rw("Total Input", totals)),
        ("Output Tokens", rw("Output Tokens", outputs)),
    ]
    if show_tags:
        cols.append(("Tags", lw("Tags", all_tags)))
    return cols, show_tags


def _build_row(values, cols_by_name):
    """Build a table row from a list of (value, col_name) pairs."""
    parts = []
    for value, name in values:
        _, width = cols_by_name[name]
        if width < 0:
            parts.append(f"{value:<{-width}}")
        else:
            parts.append(f"{value:>{width}}")
    return "  ".join(parts)


def report(rows, from_date, to_date):
    _join = lambda t: " | ".join(t) if t else ""
    if from_date is None:
        header = "Token Usage Report — all data"
    else:
        to_display = to_date - timedelta(days=1)
        if (to_display - from_date).days < 1:
            header = f"Token Usage Report — {from_date.strftime('%Y-%m-%d')}"
        else:
            header = f"Token Usage Report — {from_date.strftime('%Y-%m-%d')} to {to_display.strftime('%Y-%m-%d')}"
    print(header)
    print()

    if not rows:
        print("No usage data found.")
        return

    cols, show_tags = _col_widths(rows)
    cols_by_name = {name: (name, width) for name, width in cols}

    header_line = "  ".join(f"{label:<{-width}}" if width < 0 else f"{label:>{width}}" for label, width in cols)
    print(header_line)
    print("  ".join("─" * abs(w) for _, w in cols))

    _blank = [("", "Programmatic")]

    last_project = None
    proj_input = proj_output = proj_read = proj_create = proj_reqs = 0
    tot_input = tot_output = tot_read = tot_create = tot_reqs = 0

    def flush_project():
        nonlocal proj_input, proj_output, proj_read, proj_create, proj_reqs
        if last_project is not None and proj_reqs:
            vals = [("(subtotal)", "Project")] + _blank + [
                (fmt(proj_reqs), "Reqs"),
                (fmt(proj_input), "Input (base)"),
                (fmt(proj_read), "Cache Read"),
                (fmt(proj_create), "Cache Create"),
                (fmt(proj_input + proj_read + proj_create), "Total Input"),
                (fmt(proj_output), "Output Tokens"),
            ]
            print(_build_row(vals, cols_by_name))
            print()
        proj_input = proj_output = proj_read = proj_create = proj_reqs = 0

    for r in rows:
        if r["project"] != last_project:
            flush_project()
            last_project = r["project"]

        vals = [
            (r["project"], "Project"),
            (r["programmatic"], "Programmatic"),
            (fmt(r["requests"]), "Reqs"),
            (fmt(r["input_tokens"]), "Input (base)"),
            (fmt(r["cache_read"]), "Cache Read"),
            (fmt(r["cache_create"]), "Cache Create"),
            (fmt(r["input_tokens"] + r["cache_read"] + r["cache_create"]), "Total Input"),
            (fmt(r["output_tokens"]), "Output Tokens"),
        ]
        if show_tags:
            vals.append((_join(r["tags"]), "Tags"))
        print(_build_row(vals, cols_by_name))

        proj_input += r["input_tokens"]
        proj_output += r["output_tokens"]
        proj_read += r["cache_read"]
        proj_create += r["cache_create"]
        proj_reqs += r["requests"]

        tot_input += r["input_tokens"]
        tot_output += r["output_tokens"]
        tot_read += r["cache_read"]
        tot_create += r["cache_create"]
        tot_reqs += r["requests"]

    flush_project()

    total_vals = [("TOTAL", "Project")] + _blank + [
        (fmt(tot_reqs), "Reqs"),
        (fmt(tot_input), "Input (base)"),
        (fmt(tot_read), "Cache Read"),
        (fmt(tot_create), "Cache Create"),
        (fmt(tot_input + tot_read + tot_create), "Total Input"),
        (fmt(tot_output), "Output Tokens"),
    ]
    print(_build_row(total_vals, cols_by_name))


def csv_report(rows):
    if not rows:
        return

    show_tags = any(r.get("tags") for r in rows)
    headers = ["Project", "Programmatic", "Reqs", "Input (base)", "Cache Read", "Cache Create", "Total Input", "Output Tokens"]
    if show_tags:
        headers.append("Tags")

    writer = csv.writer(sys.stdout)
    writer.writerow(headers)
    for r in rows:
        total_input = r["input_tokens"] + r["cache_read"] + r["cache_create"]
        row = [r["project"], r["programmatic"], r["requests"], r["input_tokens"],
               r["cache_read"], r["cache_create"], total_input, r["output_tokens"]]
        if show_tags:
            row.append(" | ".join(r["tags"]) if r["tags"] else "")
        writer.writerow(row)


def main():
    params = parse_args()
    from_date, to_date = resolve_window(params)

    if params["add_tags"] or params["remove_tags"]:
        n, files = retag(params["root"], from_date, to_date,
                         params["tags"], params["add_tags"], params["remove_tags"])
        print(f"Retagged {n} entr{'y' if n == 1 else 'ies'} across {files} file(s).")
        return

    entries = collect_entries(params["root"], from_date, to_date, tag_filters=params["tags"])
    rows = aggregate(entries)
    if params["json"]:
        output = {
            "from": from_date.strftime("%Y-%m-%d") if from_date else None,
            "to": (to_date - timedelta(days=1)).strftime("%Y-%m-%d") if params["to"] else None,
            "rows": rows,
        }
        json.dump(output, sys.stdout, separators=(",", ":"))
        print()
    elif params["csv"]:
        csv_report(rows)
    else:
        report(rows, from_date, to_date)


if __name__ == "__main__":
    main()
