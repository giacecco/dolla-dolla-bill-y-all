#!/usr/bin/env node
'use strict';

/**
 * Aggregate token usage across multiple Claude Code projects and Claude Desktop.
 *
 * Usage:
 *   ddbya-report ROOT_FOLDER [OPTIONS]
 *   ddbya-report ROOT_FOLDER -t <filter> -t +<tag>   add tags to matching entries
 *   ddbya-report ROOT_FOLDER -t <filter> -t -<tag>   remove tags from matching entries
 *
 * Claude Desktop consumption (logged by the ddbya Desktop app) is always included
 * as a project named "*Claude Desktop*", alongside the folder-based projects.
 *
 * Zero npm dependencies — Node.js built-ins only.
 */

// Exit quietly when stdout is closed early (e.g. piped into head or a pager)
process.stdout.on('error', err => {
  if (err.code === 'EPIPE') process.exit(0);
  throw err;
});

const path = require('path');
const {
  CLAUDE_DESKTOP_PROJECT,
  collectEntries,
  retag,
  aggregate,
  report,
  csvReport,
  loadPricingCsv,
  computeRowCost,
} = require(path.join(__dirname, 'report-core.js'));

const HELP = `\
Usage: ddbya-report ROOT_FOLDER [OPTIONS]

Aggregate token usage across Claude Code projects and Claude Desktop.

Arguments:
  ROOT_FOLDER           Directory to scan. If it directly contains a .ddbya.d/
                        folder, reports on that project only; otherwise scans
                        all subdirectories recursively. Claude Desktop logs are
                        always included as project "${CLAUDE_DESKTOP_PROJECT}".

Filtering:
  --last N              Include only the last N days.
  --today               Include only today's entries. Exclusive with --last/--from/--to.
  --from YYYY-MM-DD     Include entries on or after this date.
  --to   YYYY-MM-DD     Include entries up to and including this date.
  -t, --tag <value>     Filter to entries matching this tag (AND logic; repeatable).
                        Wrap in /…/ for regex: -t /^client/
  --model <value>       Filter to entries matching this model (OR logic; repeatable).
                        Wrap in /…/ for regex: --model /sonnet/

Output:
  --json                Output compact JSON instead of a table.
  --csv                 Output CSV with a header row.
  (default)             Print a formatted table to stdout.

Retagging (modifies files in-place; cannot combine with --json/--csv):
  -t +tagname           Add "tagname" to every matching entry.
  -t -tagname           Remove "tagname" from every matching entry.
  -t -/regex/           Remove tags matching regex from every matching entry.
  --claude-desktop      Also retag Claude Desktop log files. Without this flag,
                        retagging only touches files under ROOT_FOLDER (reports
                        always include Claude Desktop regardless).

  Example: ddbya-report . -t foobar -t +hello
           Adds "hello" to every entry that already has tag "foobar".

Other:
  -h, --help            Show this message and exit.`;

// ── Argument parsing ──────────────────────────────────────────────────────────

function parseArgs() {
  const args = process.argv.slice(2);

  if (!args.length || args[0] === '-h' || args[0] === '--help') {
    process.stdout.write(HELP + '\n');
    process.exit(0);
  }

  const root = args[0];
  const fs = require('fs');
  if (!fs.existsSync(root) || !fs.statSync(root).isDirectory()) {
    process.stderr.write(`Not a directory: ${root}\n`);
    process.exit(1);
  }

  const params = {
    root,
    last: null,
    from: null,
    to: null,
    today: false,
    tags: [],
    addTags: [],
    removeTags: [],
    models: [],
    json: false,
    csv: false,
    dollarsPath: null,
    claudeDesktop: false,
  };

  const VALUE_FLAGS = ['--last', '--from', '--to', '-t', '--tag', '--model', '--dollars'];
  function requireValue(i) {
    if (i + 1 >= args.length) {
      process.stderr.write(`error: ${args[i]} requires a value\n`);
      process.exit(1);
    }
  }

  let i = 1;
  while (i < args.length) {
    const arg = args[i];
    if (VALUE_FLAGS.includes(arg)) requireValue(i);
    if (arg === '-h' || arg === '--help') {
      process.stdout.write(HELP + '\n');
      process.exit(0);
    } else if (arg === '--last') {
      const n = parseInt(args[++i], 10);
      if (isNaN(n)) { process.stderr.write(`Invalid --last value: ${args[i]}\n`); process.exit(1); }
      params.last = n; i++;
    } else if (arg === '--from') {
      const val = args[++i];
      if (!/^\d{4}-\d{2}-\d{2}$/.test(val)) { process.stderr.write(`Invalid --from date (expected YYYY-MM-DD): ${val}\n`); process.exit(1); }
      params.from = val; i++;
    } else if (arg === '--to') {
      const val = args[++i];
      if (!/^\d{4}-\d{2}-\d{2}$/.test(val)) { process.stderr.write(`Invalid --to date (expected YYYY-MM-DD): ${val}\n`); process.exit(1); }
      params.to = val; i++;
    } else if (arg === '--today') {
      params.today = true; i++;
    } else if (arg === '-t' || arg === '--tag') {
      const val = args[++i];
      const isRegex = val.startsWith('/') && val.endsWith('/') && val.length > 2;
      if (!isRegex && val.startsWith('+')) {
        const tag = val.slice(1);
        if (!tag) { process.stderr.write('error: -t/+ requires a tag name\n'); process.exit(1); }
        params.addTags.push(tag);
      } else if (!isRegex && val.startsWith('-')) {
        const tag = val.slice(1);
        if (!tag) { process.stderr.write('error: -t/- requires a tag name\n'); process.exit(1); }
        params.removeTags.push(tag);
      } else {
        params.tags.push(val);
      }
      i++;
    } else if (arg === '--model') {
      params.models.push(args[++i]); i++;
    } else if (arg === '--json') {
      params.json = true; i++;
    } else if (arg === '--csv') {
      params.csv = true; i++;
    } else if (arg === '--dollars') {
      params.dollarsPath = args[++i]; i++;
    } else if (arg === '--claude-desktop') {
      params.claudeDesktop = true; i++;
    } else {
      process.stderr.write(`Unknown argument: ${arg}\n`); process.exit(1);
    }
  }

  if (params.today && (params.last !== null || params.from || params.to)) {
    process.stderr.write('error: --today cannot be combined with --last, --from, or --to\n'); process.exit(1);
  }
  if (params.last !== null && (params.from || params.to)) {
    process.stderr.write('error: --last cannot be combined with --from or --to\n'); process.exit(1);
  }
  if (params.json && params.csv) {
    process.stderr.write('error: --json and --csv are mutually exclusive\n'); process.exit(1);
  }
  if ((params.addTags.length || params.removeTags.length) && (params.json || params.csv)) {
    process.stderr.write('error: retagging (-t +/-) cannot be combined with --json or --csv\n'); process.exit(1);
  }
  if (params.claudeDesktop && !params.addTags.length && !params.removeTags.length) {
    process.stderr.write('error: --claude-desktop only applies to retagging (reports always include Claude Desktop)\n'); process.exit(1);
  }

  return params;
}

// ── Time window ───────────────────────────────────────────────────────────────

// Dates given by the user are interpreted as local calendar days (local
// midnight boundaries); log timestamps are stored in UTC but compared as
// absolute instants, so this needs no data conversion.
function localMidnight(ymd, plusDays) {
  const [y, m, d] = ymd.split('-').map(Number);
  return new Date(y, m - 1, d + (plusDays || 0));
}

function resolveWindow(params) {
  const now = new Date();

  if (params.today) {
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    return { fromDate: today, toDate: new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1) };
  }

  let toDate = null;
  if (params.to) {
    toDate = localMidnight(params.to, 1); // exclusive upper bound
  }

  let fromDate = null;
  if (params.from) {
    fromDate = localMidnight(params.from);
    if (!toDate) toDate = now;
  } else if (params.last !== null) {
    fromDate = new Date(now.getTime() - params.last * 86400000);
    if (!toDate) toDate = now;
  }

  return { fromDate, toDate };
}

function localDateStr(d) {
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}

// ── Main ──────────────────────────────────────────────────────────────────────

function main() {
  const params = parseArgs();
  const { fromDate, toDate } = resolveWindow(params);

  if (params.addTags.length || params.removeTags.length) {
    const { modifiedEntries, modifiedFiles, files } = retag(
      params.root, fromDate, toDate, params.tags, params.addTags, params.removeTags, params.claudeDesktop,
    );
    for (const f of files) {
      const n = f.entries === 1 ? 'entry' : 'entries';
      process.stdout.write(`  ${f.path}: ${f.entries} ${n}\n`);
    }
    const noun = modifiedEntries === 1 ? 'entry' : 'entries';
    process.stdout.write(`Retagged ${modifiedEntries} ${noun} across ${modifiedFiles} file(s).\n`);
    return;
  }

  const entries = collectEntries(params.root, fromDate, toDate, params.tags, params.models);
  const rows = aggregate(entries);

  let pricingData = null;
  if (params.dollarsPath) {
    pricingData = loadPricingCsv(params.dollarsPath);
    if (!pricingData) {
      process.stderr.write(`ddbya-report: could not load pricing CSV: ${params.dollarsPath}\n`);
      process.exit(1);
    }
  }

  if (params.json) {
    const output = {
      from: fromDate ? localDateStr(fromDate) : null,
      to: toDate ? localDateStr(new Date(toDate.getTime() - 1)) : null,
      rows: pricingData
        ? rows.map(r => {
            const cost = computeRowCost(r, pricingData);
            return { ...r, cost_usd: cost !== null ? +cost.toFixed(6) : null };
          })
        : rows,
    };
    process.stdout.write(JSON.stringify(output) + '\n');
  } else if (params.csv) {
    process.stdout.write(csvReport(rows, pricingData));
  } else {
    report(rows, fromDate, toDate, pricingData);
  }
}

main();
