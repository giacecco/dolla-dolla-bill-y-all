{
  "name": "ddbya-desktop",
  "version": "1.0.0",
  "description": "ddbya Desktop — token usage monitor for Claude Desktop",
  "author": "Gianfranco Cecconi",
  "main": "main.js",
  "scripts": {
    "prestart": "node macos/generate-icons.js",
    "start": "electron .",
    "build:mac": "bash macos/build.sh",
    "build:win": "npx electron-builder --win --config windows/electron-builder.yml"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "allowScripts": {
    "electron@33.4.11": true
  }
}
