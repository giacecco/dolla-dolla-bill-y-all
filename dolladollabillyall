#!/usr/bin/env python3
"""
Reverse proxy wrapper for Claude Code that intercepts and logs token consumption.
Zero dependencies — Python 3 standard library only.

Usage:
    dolladollabillyall [claude args...]

The proxy writes token usage to ./token-usage.jsonl in the current directory
and prints a summary to stderr when the session ends.
"""

import sys
import os
import json
import threading
import subprocess
import http.server
import http.client
import urllib.parse
import signal
from datetime import datetime, timezone
from pathlib import Path

TOKEN_LOG_FILE = "token-usage.jsonl"
DEFAULT_UPSTREAM = "https://api.anthropic.com"


class TokenLogger:
    """Writes token usage to a project-local JSONL file and tracks session totals."""

    def __init__(self, log_path):
        self._log_path = Path(log_path)
        self._lock = threading.Lock()
        self.session_entries = []

    def log(self, entry):
        entry["timestamp"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        with self._lock:
            self.session_entries.append(entry)
            with open(self._log_path, "a") as f:
                f.write(json.dumps(entry, sort_keys=True) + "\n")

    def summary(self):
        with self._lock:
            entries = list(self.session_entries)
        total_input = sum(e.get("input_tokens", 0) for e in entries)
        total_output = sum(e.get("output_tokens", 0) for e in entries)
        return total_input, total_output, len(entries)


class ReverseProxyHandler(http.server.BaseHTTPRequestHandler):
    """Handles incoming requests by forwarding them to the upstream Anthropic API."""

    # Set by ReverseProxy at server creation time
    upstream_scheme = "https"
    upstream_netloc = "api.anthropic.com"
    token_logger = None

    # Suppress http.server's default request logging
    def log_message(self, format, *args):
        pass

    def _log_token_usage(self, model, stream, input_tokens, output_tokens):
        endpoint = self.path.split("?")[0].lstrip("/")
        self.token_logger.log({
            "model": model,
            "endpoint": endpoint,
            "stream": stream,
            "input_tokens": input_tokens,
            "output_tokens": output_tokens,
        })

    def _forward(self, method):
        # Read the request body
        content_length = int(self.headers.get("Content-Length", 0))
        req_body = self.rfile.read(content_length) if content_length else b""

        # Forward to upstream
        if self.upstream_scheme == "https":
            conn = http.client.HTTPSConnection(self.upstream_netloc, timeout=300)
        else:
            conn = http.client.HTTPConnection(self.upstream_netloc, timeout=300)

        upstream_headers = {}
        for key, value in self.headers.items():
            low = key.lower()
            if low not in ("host", "connection", "proxy-connection"):
                upstream_headers[key] = value

        try:
            conn.request(method, self.path, body=req_body, headers=upstream_headers)
            resp = conn.getresponse()

            # Determine if this is a streaming request
            is_streaming = False
            if req_body:
                try:
                    is_streaming = json.loads(req_body).get("stream", False)
                except json.JSONDecodeError:
                    pass

            # Relay response status and headers
            self.send_response(resp.status, resp.reason)
            for key, value in resp.getheaders():
                low = key.lower()
                if low not in ("transfer-encoding", "connection", "keep-alive"):
                    self.send_header(key, value)
            self.end_headers()

            if is_streaming:
                self._relay_stream(resp, req_body)
            else:
                resp_body = resp.read()
                self.wfile.write(resp_body)
                self._extract_usage_nonstream(resp_body, req_body)
        finally:
            conn.close()

    def _relay_stream(self, resp, req_body):
        """Relay SSE events chunk by chunk, then extract usage from the final event."""
        sse_text = b""
        while True:
            chunk = resp.read(4096)
            if not chunk:
                break
            self.wfile.write(chunk)
            self.wfile.flush()
            sse_text += chunk
        self._extract_usage_sse(sse_text, req_body)

    def _extract_usage_nonstream(self, resp_body, req_body):
        try:
            data = json.loads(resp_body)
            usage = data.get("usage")
            if not usage:
                return
            self._log_token_usage(
                model=data.get("model", ""),
                stream=False,
                input_tokens=usage.get("input_tokens", 0),
                output_tokens=usage.get("output_tokens", 0),
            )
        except (json.JSONDecodeError, KeyError):
            pass

    def _extract_usage_sse(self, sse_text, req_body):
        try:
            req_model = ""
            if req_body:
                try:
                    req_model = json.loads(req_body).get("model", "")
                except json.JSONDecodeError:
                    pass

            best_input = 0
            best_output = 0
            best_model = req_model

            for line in sse_text.decode("utf-8", errors="replace").split("\n"):
                if not line.startswith("data: "):
                    continue
                try:
                    event = json.loads(line[6:])
                except json.JSONDecodeError:
                    continue

                event_type = event.get("type", "")
                if event_type in ("message_stop", "message_delta"):
                    usage = event.get("usage")
                    if usage:
                        if usage.get("input_tokens", 0) > 0:
                            best_input = usage["input_tokens"]
                        if usage.get("output_tokens", 0) > 0:
                            best_output = usage["output_tokens"]
                        if event.get("model"):
                            best_model = event["model"]

            if best_input > 0 or best_output > 0:
                self._log_token_usage(
                    model=best_model,
                    stream=True,
                    input_tokens=best_input,
                    output_tokens=best_output,
                )
        except Exception:
            pass

    # Dispatch every HTTP method to the forwarder
    do_GET = lambda self: self._forward("GET")
    do_POST = lambda self: self._forward("POST")
    do_PUT = lambda self: self._forward("PUT")
    do_DELETE = lambda self: self._forward("DELETE")
    do_PATCH = lambda self: self._forward("PATCH")
    do_OPTIONS = lambda self: self._forward("OPTIONS")
    do_HEAD = lambda self: self._forward("HEAD")


class ReverseProxy:
    """Manages the lifecycle of the reverse proxy HTTP server."""

    def __init__(self, upstream_url):
        parsed = urllib.parse.urlparse(upstream_url)
        if parsed.scheme and parsed.netloc:
            self.upstream_scheme = parsed.scheme
            self.upstream_netloc = parsed.netloc
        else:
            default = urllib.parse.urlparse(DEFAULT_UPSTREAM)
            self.upstream_scheme = default.scheme
            self.upstream_netloc = default.netloc

        self.token_logger = TokenLogger(TOKEN_LOG_FILE)
        self._server = None
        self._thread = None

    @property
    def port(self):
        return self._server.server_address[1] if self._server else None

    def start(self):
        # Bind to port 0 to let the OS pick a free port
        handler = self._build_handler()
        self._server = http.server.ThreadingHTTPServer(("127.0.0.1", 0), handler)
        self._thread = threading.Thread(target=self._server.serve_forever, daemon=True)
        self._thread.start()

    def stop(self):
        if self._server:
            self._server.shutdown()

    def _build_handler(self):
        token_logger = self.token_logger
        upstream_scheme = self.upstream_scheme
        upstream_netloc = self.upstream_netloc

        class BoundHandler(ReverseProxyHandler):
            pass

        BoundHandler.token_logger = token_logger
        BoundHandler.upstream_scheme = upstream_scheme
        BoundHandler.upstream_netloc = upstream_netloc
        return BoundHandler


def format_summary(input_tokens, output_tokens, request_count):
    lines = [
        "\nSession token usage:",
        f"  Requests:  {request_count}",
        f"  Input:     {input_tokens:,} tokens",
        f"  Output:    {output_tokens:,} tokens",
        f"  Total:     {input_tokens + output_tokens:,} tokens",
    ]
    return "\n".join(lines)


def main():
    # Preserve the original upstream URL if already set
    upstream = os.environ.get("ANTHROPIC_BASE_URL", DEFAULT_UPSTREAM)

    proxy = ReverseProxy(upstream)
    proxy.start()

    env = os.environ.copy()
    env["ANTHROPIC_BASE_URL"] = f"http://127.0.0.1:{proxy.port}"

    claude_args = sys.argv[1:] if len(sys.argv) > 1 else []

    # Restore default SIGINT behaviour so Ctrl+C is forwarded to claude naturally.
    # Python installs its own SIGINT handler that raises KeyboardInterrupt;
    # restoring SIG_DFL lets the claude subprocess receive the signal directly.
    original_sigint = signal.signal(signal.SIGINT, signal.SIG_DFL)

    try:
        result = subprocess.run(
            ["claude"] + claude_args,
            env=env,
            stdin=sys.stdin,
            stdout=sys.stdout,
            stderr=sys.stderr,
        )
        exit_code = result.returncode
    finally:
        signal.signal(signal.SIGINT, original_sigint)
        proxy.stop()

    input_tokens, output_tokens, request_count = proxy.token_logger.summary()
    if request_count > 0:
        print(format_summary(input_tokens, output_tokens, request_count), file=sys.stderr)

    sys.exit(exit_code)


if __name__ == "__main__":
    main()
